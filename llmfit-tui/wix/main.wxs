<?xml version='1.0' encoding='windows-1252'?>
<!--
  Copyright (C) 2026 Alex Jones

  WiX installer definition for llmfit.
  Do not change the UpgradeCode GUID — it must remain stable across versions
  to support clean in-place upgrades.
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='llmfit'
        UpgradeCode='B1F6A4C9-7D2E-4A8B-9C3F-E5D1A0B2C4D6'
        Manufacturer='Alex Jones'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='llmfit - Right-size LLM models to your system hardware'
            Manufacturer='Alex Jones'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252' />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.' />

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1' />
        <Property Id='DiskPrompt' Value='llmfit Installation' />

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFiles64Folder' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='llmfit'>

                    <Component Id='binary0' Guid='A7C3E1F9-5B2D-4E8A-9F6C-D0B4A2E8C1F3' Win64='yes'>
                        <File
                            Id='exe0'
                            Name='llmfit.exe'
                            DiskId='1'
                            Source='$(var.CargoTargetBinDir)\llmfit.exe'
                            KeyPath='yes' />
                    </Component>

                    <Component Id='Path' Guid='C8D2F4A6-3E1B-4C9D-8A7F-B5E0D6A3F2C1' Win64='yes'>
                        <Environment
                            Id='PATH'
                            Name='PATH'
                            Value='[APPLICATIONFOLDER]'
                            Permanent='no'
                            Part='last'
                            Action='set'
                            System='yes' />
                    </Component>

                    <Component Id='License' Guid='E9F1A3C5-2D4B-4E8C-9A6F-D7B0C2E4A1F5' Win64='yes'>
                        <File
                            Id='LicenseFile'
                            Name='LICENSE'
                            DiskId='1'
                            Source='..\LICENSE'
                            KeyPath='yes' />
                    </Component>

                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='llmfit'
            Description='Installs llmfit.exe and adds it to the system PATH.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='binary0' />
            <ComponentRef Id='Path' />
            <ComponentRef Id='License' />
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize' />

        <!-- UI: minimal with license agreement -->
        <UIRef Id='WixUI_Minimal' />
        <WixVariable Id='WixUILicenseRtf' Value='wix\License.rtf' />

    </Product>

</Wix>
